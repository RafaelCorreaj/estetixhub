# ============================================
# Variáveis de Ambiente - Produção
# Copie este arquivo para .env.prod e preencha
# ============================================

# Banco de dados
DB_PASSWORD=sua_senha_aqui

# JWT
JWT_SECRET=seu_segredo_jwt_super_seguro_aqui

# URLs da aplicação (opcional - padrão: /api)
# VITE_API_URL=/api

# ============================================
# Configurações do Docker Hub (GitHub Secrets)
# ============================================
# DOCKER_HUB_USERNAME=seu_usuario
# DOCKER_HUB_TOKEN=seu_token_docker_hub

# ============================================
# Configurações da EC2 (GitHub Secrets)
# ============================================
# EC2_HOST=3.235.24.227
# EC2_USER=ec2-user
# EC2_SSH_PRIVATE_KEY=chave_privada_ssh_completa

# ============================================
# IMPORTANTE:
# 1. Nunca comite o arquivo .env.prod no git
# 2. Configure as variáveis acima nos Secrets do GitHub
# 3. Na EC2, crie um arquivo .env.prod com DB_PASSWORD e JWT_SECRET
# ============================================