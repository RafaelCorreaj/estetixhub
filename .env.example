# Configurações do Banco de Dados
DB_PASSWORD=sua_senha_aqui
DATABASE_URL=postgresql://estetixhub:${DB_PASSWORD}@localhost:5432/estetixhub

# JWT Secret (use um valor forte e aleatório em produção)
JWT_SECRET=seu_jwt_secret_aqui_mude_isso

# Configurações da API
API_URL=http://localhost:3000
NODE_ENV=development

# Configurações de Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app

# Configurações de Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# Configurações de Pagamento (opcional - Stripe)
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Configurações de WhatsApp/Telegram (opcional)
WHATSAPP_TOKEN=seu_token_aqui
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui